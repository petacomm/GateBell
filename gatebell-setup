# ── Already registered ────────────────────────────────────────────────────────
def already_registered():
    return os.path.exists(USER_ID_FILE) and os.path.exists(CONFIG_FILE)

def load_config():
    with open(CONFIG_FILE) as f:
        return json.load(f)

# ── Save config ───────────────────────────────────────────────────────────────
def save_config(user_id, client_secret, alias):
    os.makedirs("/etc/gatebell", exist_ok=True)
    os.chmod("/etc/gatebell", 0o700)

    with open(USER_ID_FILE, "w") as f:
        f.write(user_id)
    os.chmod(USER_ID_FILE, 0o600)

    config = {
        "user_id":       user_id,
        "client_secret": client_secret,
        "alias":         alias,
        "server_url":    GATEBELL_SERVER_URL,
    }
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)
    os.chmod(CONFIG_FILE, 0o600)

    ok(f"Your settings have been saved safely.")

# ── Registration ──────────────────────────────────────────────────────────────
def register():
    step(1, "Enter your email address")
    print(f"  {C.DIM}We'll send a 6-digit code to verify it's really you.{C.RESET}")
    print(f"  {C.DIM}Use any email you check regularly — Gmail, Outlook, etc.{C.RESET}")
    print()

    email = input(f"  {C.BOLD}Your email address:{C.RESET} ").strip().lower()
    if not email or "@" not in email:
        err("That doesn't look like a valid email address.\n  Example: john@gmail.com\n  Please run gatebell-setup again and try once more.")

    print()
    info(f"Sending a verification code to {C.BOLD}{email}{C.RESET} ...")
    info(f"This usually arrives within 30 seconds.")

    try:
        resp = requests.post(
            f"{GATEBELL_SERVER_URL}/register/start",
            json={"email": email},
            timeout=15
        )
        data = resp.json()
    except Exception as e:
        err(f"We couldn't reach the GateBell server.\n  Please check your internet connection and try again.\n  Details: {e}")

    if not data.get("ok"):
        err(f"Something went wrong: {data.get('error', 'Unknown error')}\n  Please try again or visit kotechsoft.com for help.")

    ok("Email sent! Check your inbox now.")
    print(f"  {C.DIM}Can't find it? Check your spam/junk folder too.{C.RESET}")
    print()

    step(2, "Enter your verification code")
    print(f"  {C.DIM}Open the email from GateBell and type the 6-digit code below.{C.RESET}")
    print(f"  {C.DIM}The code looks like: 482910{C.RESET}")
    print()

    code = input(f"  {C.BOLD}6-digit code:{C.RESET} ").strip()
    if len(code) != 6 or not code.isdigit():
        err("The code must be exactly 6 numbers (like: 482910).\n  Please run gatebell-setup again and try once more.")

    print()
    step(3, "Give this server a nickname")
    print(f"  {C.DIM}This nickname will appear in your email alerts so you know{C.RESET}")
    print(f"  {C.DIM}which server was accessed. Pick something easy to recognize.{C.RESET}")
    print()
    print(f"  {C.DIM}Good examples:{C.RESET}")
    print(f"  {C.DIM}  · my-vps{C.RESET}")
    print(f"  {C.DIM}  · web-server{C.RESET}")
    print(f"  {C.DIM}  · home-lab{C.RESET}")
    print(f"  {C.DIM}  · office-pc{C.RESET}")
    print()

    alias = input(f"  {C.BOLD}Server nickname:{C.RESET} ").strip()
    if not alias:
        err("Nickname cannot be empty. Please run gatebell-setup again.")

    print()
    info("Verifying your code with GateBell server...")

    try:
        resp = requests.post(
            f"{GATEBELL_SERVER_URL}/register/verify",
            json={"email": email, "code": code, "alias": alias},
            timeout=15
        )
        data = resp.json()
    except Exception as e:
        err(f"We couldn't reach the GateBell server.\n  Please check your internet connection and try again.\n  Details: {e}")

    if not data.get("ok"):
        err(f"Verification failed: {data.get('error', 'Unknown error')}\n  The code may have expired (codes are valid for 10 minutes).\n  Please run gatebell-setup again to get a new code.")

    user_id       = data["user_id"]
    client_secret = data["client_secret"]

    print()
    ok(f"Identity verified! Your account is ready.")
    print()
    print(f"  {C.DIM}Your server nickname : {C.RESET}{C.BOLD}{alias}{C.RESET}")
    print(f"  {C.DIM}A unique security key has been saved to this server.{C.RESET}")
    print(f"  {C.DIM}You don't need to remember it — GateBell handles it automatically.{C.RESET}")

    return user_id, client_secret, alias

# ── Notifier script ───────────────────────────────────────────────────────────
def write_notifier_script():
    script = textwrap.dedent(f"""
        #!/usr/bin/env python3
        # GateBell Notifier v1.0 — by Kotech Petacomm
        # This runs automatically in the background on every SSH login.
        # You don't need to run or edit this file.

        import os, sys, json, hmac, hashlib, requests, secrets
        from datetime import datetime, timezone

        CONFIG_FILE = "/etc/gatebell/config.json"

        def load_config():
            with open(CONFIG_FILE) as f:
                return json.load(f)

        def sign(payload_bytes, secret):
            return hmac.new(secret.encode(), payload_bytes, hashlib.sha256).hexdigest()

        def main():
            if os.environ.get("PAM_TYPE", "") != "open_session":
                sys.exit(0)

            connecting_ip = os.environ.get("PAM_RHOST", "unknown")
            login_dt      = datetime.now(timezone.utc).astimezone().isoformat()
            nonce         = secrets.token_hex(16)

            try:
                cfg = load_config()
            except Exception as e:
                print(f"[GateBell] Could not read config: {{e}}", file=sys.stderr)
                sys.exit(0)

            payload = {{
                "user_id":       cfg["user_id"],
                "connecting_ip": connecting_ip,
                "login_dt":      login_dt,
            }}

            import json as _json
            payload_bytes = _json.dumps(payload, separators=(',', ':')).encode()

            try:
                requests.post(
                    f"{{cfg['server_url']}}/ssh/login",
                    data=payload_bytes,
                    headers={{
                        "Content-Type":          "application/json",
                        "X-GateBell-Signature":  sign(payload_bytes, cfg["client_secret"]),
                        "X-GateBell-Nonce":      nonce,
                        "X-GateBell-Timestamp":  login_dt,
                    }},
                    timeout=8
                )
            except Exception as e:
                print(f"[GateBell] Could not send notification: {{e}}", file=sys.stderr)

            sys.exit(0)

        if __name__ == "__main__":
            main()
    """).strip()

    with open(NOTIFIER_SCRIPT, "w") as f:
        f.write(script)
    os.chmod(NOTIFIER_SCRIPT, 0o755)
    ok(f"Notification engine installed.")

def write_pam_script():
    script = textwrap.dedent(f"""
        #!/bin/bash
        # GateBell PAM Wrapper v1.0 — by Kotech Petacomm
        # This file connects GateBell to the SSH login system.
        # You don't need to edit this file.
        export PAM_TYPE="$PAM_TYPE"
        export PAM_RHOST="$PAM_RHOST"
        export PAM_USER="$PAM_USER"
        /usr/bin/python3 {NOTIFIER_SCRIPT} &
        exit 0
    """).strip()

    with open(PAM_SCRIPT, "w") as f:
        f.write(script)
    os.chmod(PAM_SCRIPT, 0o755)
    ok(f"SSH connector installed.")

def configure_pam():
    PAM_SSHD = "/etc/pam.d/sshd"
    MARKER   = "# GateBell"
    PAM_LINE = f"session optional pam_exec.so seteuid {PAM_SCRIPT} {MARKER}"

    try:
        with open(PAM_SSHD) as f:
            content = f.read()
    except FileNotFoundError:
        warn(f"SSH config file not found at {PAM_SSHD}.")
        warn("Please contact support at kotechsoft.com for help.")
        return

    if MARKER in content:
        warn("GateBell is already connected to SSH. Skipping.")
        return

    with open(PAM_SSHD, "a") as f:
        f.write(f"\n{PAM_LINE}\n")

    ok("GateBell connected to SSH successfully.")
    info("Applying changes (restarting SSH service)...")
    os.system("systemctl restart sshd 2>/dev/null || service ssh restart 2>/dev/null || true")
    ok("Done! SSH service is back up and running.")

def install_requests():
    result = subprocess.run([sys.executable, "-c", "import requests"], capture_output=True)
    if result.returncode != 0:
        info("Installing a required Python package...")
        os.system("apt-get install -y -qq python3-requests 2>/dev/null || pip3 install requests -q")
    ok("All dependencies are ready.")

