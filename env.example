# GateBell Server — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your .env file to version control!

# ── Flask ────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
FLASK_SECRET_KEY=your_long_random_secret_key_here

# ── Email (Brevo SMTP) ───────────────────────────────────────────────────────
# Sign up at: https://app.brevo.com
# Go to: Settings → SMTP & API → Generate a new SMTP key
BREVO_SMTP_LOGIN=your_brevo_login@smtp-brevo.com
BREVO_SMTP_PASSWORD=your_brevo_smtp_key_here

# Sender address shown in email alerts
# Must be a verified domain in your Brevo account
GATEBELL_FROM=GateBell <gatebell@yourdomain.com>

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=/opt/gatebell/db/gatebell.db

# ── IP Geolocation API ───────────────────────────────────────────────────────
# Free, no registration required
IP_API_URL=http://ip-api.com/json
